# Database
POSTGRES_USER=dms
POSTGRES_PASSWORD=dms_secret
POSTGRES_DB=dms
DATABASE_URL=postgresql+asyncpg://dms:dms_secret@postgres:5432/dms

# Redis
REDIS_URL=redis://redis:6379/0

# Storage
STORAGE_BACKEND=local
# S3/MinIO settings (when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dms-documents

# Local storage
LOCAL_STORAGE_PATH=/data/documents

# Auth
SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin user (auto-created on startup)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# Registration
REGISTRATION_ENABLED=true

# SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# SSO / OIDC (Keycloak, Azure AD, Okta, Google, Auth0)
SSO_ENABLED=false
SSO_PROVIDER_NAME=Keycloak
SSO_CLIENT_ID=dms
SSO_CLIENT_SECRET=your-client-secret
SSO_AUTHORIZATION_URL=https://keycloak.example.com/realms/dms/protocol/openid-connect/auth
SSO_TOKEN_URL=https://keycloak.example.com/realms/dms/protocol/openid-connect/token
SSO_USERINFO_URL=https://keycloak.example.com/realms/dms/protocol/openid-connect/userinfo
SSO_REDIRECT_URI=http://localhost:3000/auth/callback
SSO_SCOPES=openid email profile
SSO_AUTO_CREATE_USERS=true
SSO_DEFAULT_ROLE=user

# SAML 2.0 (Enterprise SSO)
SAML_ENABLED=false
SAML_ENTITY_ID=https://dms.example.com
SAML_SSO_URL=https://idp.example.com/sso/saml
SAML_CERTIFICATE=
SAML_ATTRIBUTE_EMAIL=email
SAML_ATTRIBUTE_USERNAME=preferred_username
SAML_ATTRIBUTE_NAME=name

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
